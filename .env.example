# ============================================================================
#  Food Hall Orchestrator — environment template
# ----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in real values:
#      Copy-Item .env.example .env      (PowerShell)
#
#  `.env` is gitignored and must NEVER be committed. Secrets (JWT_SECRET,
#  GoTab client secret) live ONLY here or in your host's secret store —
#  never in the repo, git history, code, or chat.
#
#  The app validates this on boot (src/config/index.ts, Zod) and exits with a
#  clear error if anything required is missing or malformed.
# ============================================================================

# --- Server ---
NODE_ENV=development          # development | test | production
PORT=3000
HOST=0.0.0.0

# --- Auth (REQUIRED) ---
# Admin/vendor JWT signing secret. Must be >= 16 chars; use something long.
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change_me_to_a_long_random_string

# --- Database / PostgreSQL (REQUIRED, must be a valid URL) ---
# Matches the docker-compose dev service. Change user/pass/host for prod.
DATABASE_URL=postgresql://foodhall:foodhall@localhost:5432/foodhall?schema=public

# --- Redis (REQUIRED, must be a valid URL) — queues + pub/sub + heartbeat ---
REDIS_URL=redis://localhost:6379

# --- Vendor adapter ---
# "mock"  = built-in GoTab simulator (no external calls; default for dev/demo).
# "gotab" = real GoTab integration (Phase 2; requires the OAuth vars below).
VENDOR_ADAPTER=mock

# ----------------------------------------------------------------------------
#  GoTab (only needed when VENDOR_ADAPTER=gotab — Phase 2 sandbox onward)
# ----------------------------------------------------------------------------
#  Auth is OAuth, CONFIRMED working 2026-06-26. GoTab does NOT use the
#  OAuth-standard grant_type=client_credentials form body. It is a JSON POST to
#  https://gotab.io/api/oauth/token with fields api_access_id + api_access_secret
#  (optional response_type = "token" or omitted). The response is a Bearer token
#  with a 24h TTL plus a refreshToken and your user_id; the adapter caches the
#  token and refreshes before expiry. Token goes in the Authorization header on
#  every request (not base64-encoded). Errors: 401 = expired/revoked (retry after
#  refresh); 403 = invalid (do not retry without changing the request).
#
#  Listing accessible locations is GraphQL (POST https://gotab.io/api/v2/graph),
#  NOT a REST path — REST routes are location-scoped: /api/loc/{location}/...
#
#  Leave these blank while VENDOR_ADAPTER=mock — they're optional then and the
#  app boots fine without them. Blank values are treated as UNSET (the config
#  coerces '' → undefined), so leaving template lines empty is always safe.
#
#  NOTE: the menu-IMPORT path (admin "Import from GoTab") uses REAL GoTab
#  whenever credentials are present, even in VENDOR_ADAPTER=mock — importing
#  is a read and is unblocked while order submission is not. Fill in the
#  credentials below to import live menus while the fire path stays mock.

# Endpoints. These match the config defaults — only set them to OVERRIDE
# (e.g. if GoTab ever gives you a distinct sandbox host).
GOTAB_API_BASE=https://gotab.io
GOTAB_OAUTH_URL=https://gotab.io/api/oauth/token
GOTAB_GRAPH_URL=https://gotab.io/api/v2/graph

# GoTab API credentials (Client Credentials flow). These are the REAL field
# names GoTab uses and the names the config prefers. (The legacy
# GOTAB_API_KEY / GOTAB_API_SECRET names are still read as a fallback if these
# are unset — pre-rename .env files keep working.)
GOTAB_API_ACCESS_ID=
GOTAB_API_ACCESS_SECRET=

# Sandbox location UUIDs (account identifiers, not secrets). The adapter scopes
# REST calls by these: /api/loc/{locationUuid}/... URL-ENCODE the path segment —
# two of these contain a literal '~'.
GOTAB_LOC_PARENT=EL7tpX4xTFNCq~SnMrY_0EcZ      # Detroit Shipping Sandbox
GOTAB_LOC_KONJO=ZQFbjpg06x4rf1w08RTuOhGa       # Konjo Me Sandbox
GOTAB_LOC_MOTOR=oSVMdw0wbSMqE~pOv7cUdkMd       # Motor Burger Sandbox

# Webhook signing secret (only if GoTab webhooks are enabled — Phase 2.6).
# Used to HMAC-verify POST /api/webhooks/gotab before parsing the body.
GOTAB_WEBHOOK_SECRET=

# --- Scheduling ---
# Target window (seconds) within which all items in a group should finish.
GROUP_READY_WINDOW_SECONDS=120
# How long to wait for all members to pay before dropping unpaid items.
PAYMENT_TIMEOUT_SECONDS=300
# OPEN groups idle longer than this are cancelled by the worker sweep.
GROUP_OPEN_EXPIRY_HOURS=6

# ============================================================================
#  Integration tests (npm run test:int) read these if set, else fall back to
#  the docker-compose infra with a separate DB + Redis db 1. Usually you do
#  NOT need to set them locally.
# ============================================================================
# TEST_DATABASE_URL=postgresql://foodhall:foodhall@localhost:5432/foodhall_test?schema=public
# TEST_REDIS_URL=redis://localhost:6379/1
